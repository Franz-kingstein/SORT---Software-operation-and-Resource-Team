# Ignore Python virtual environments
sort_env/

# Byte-compiled / cache files
__pycache__/
*.py[cod]
*.so
*.egg-info/

# VSCode and editor settings
.vscode/
.idea/
*.swp

# Node modules (if any frontend work)
frontend/node_modules/

# Ignore test output, logs, and temp files
*.log
*.tmp
.DS_Store

# Do NOT ignore .env (keep it tracked)
!.env
